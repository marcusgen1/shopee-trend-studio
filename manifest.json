{
  "manifest_version": 3,
  "name": "Shopee Trend Studio",
  "version": "0.1.0",
  "description": "Hut san pham top_products cua Shopee, va che anh/video viral bang AI (BytePlus Seedream/Seedance).",
  "minimum_chrome_version": "111",
  "permissions": ["storage", "downloads", "offscreen", "unlimitedStorage"],
  "host_permissions": [
    "https://shopee.vn/*",
    "https://*.shopee.vn/*",
    "https://*.susercontent.com/*",
    "https://ark.ap-southeast.bytepluses.com/*"
  ],
  "background": { "service_worker": "src/background.js" },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Shopee Trend Studio"
  },
  "options_page": "src/options.html",
  "content_scripts": [
    {
      "matches": ["https://shopee.vn/*"],
      "js": ["src/inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://shopee.vn/*"],
      "js": ["src/content.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
